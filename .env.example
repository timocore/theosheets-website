# ===========================================
# Suggested setup order (set top to bottom)
# ===========================================

# 1. Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/theosheets?schema=public"

# 2. Auth (required)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-with-openssl-rand-base64-32"

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_ENABLED=false

# 3. Admin (required for /admin)
ADMIN_EMAILS="your@email.com"

# 4. Stripe (required for checkout)
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# 5. AWS S3 (required for admin file uploads)
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
S3_PREVIEW_PREFIX="preview/"
S3_PRIVATE_PREFIX="private/"

# 6. Email (required for order confirmations, password reset, contact form)
RESEND_API_KEY="re_..."
EMAIL_FROM="TheoSheets <onboarding@resend.dev>"
# Where to receive contact form submissions (defaults to first ADMIN_EMAILS)
CONTACT_EMAIL="your@email.com"

# Site URL (for emails, links)
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Store-wide sale (optional)
# Set to 30 for 30% off everything. Omit or 0 to disable.
# NEXT_PUBLIC_SALE_PERCENT=30
